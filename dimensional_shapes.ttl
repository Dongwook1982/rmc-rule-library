# SHACL Shapes — Dimensional Tolerance Rules (DIM-001 to DIM-028)
# RMC Rule Library | Kim (2026) | ASCE JCCE
@prefix rmc:  <https://rmc.dl-enc.com/ontology#> .
@prefix ifc:  <https://standards.buildingsmart.org/IFC/DEV/IFC4_3/> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# DIM-001: PSC girder horizontal alignment deviation
rmc:DIM-001-Shape a sh:NodeShape ;
    sh:targetClass ifc:IfcBeam ;
    sh:property [
        sh:path rmc:horizontalDeviationMm ;
        sh:minInclusive -5.0 ;
        sh:maxInclusive 5.0 ;
        sh:severity sh:Violation ;
        sh:message "DIM-001 FAIL: {$value} mm violates Section4.3.2" ;
    ] .

# DIM-002: PSC girder vertical camber deviation
rmc:DIM-002-Shape a sh:NodeShape ;
    sh:targetClass ifc:IfcBeam ;
    sh:property [
        sh:path rmc:verticalCamberMm ;
        sh:minInclusive -8.0 ;
        sh:maxInclusive 8.0 ;
        sh:severity sh:Violation ;
        sh:message "DIM-002 FAIL: {$value} mm violates Section4.3.3" ;
    ] .

# DIM-003: Bearing seat level deviation
rmc:DIM-003-Shape a sh:NodeShape ;
    sh:targetClass ifc:IfcBearing ;
    sh:property [
        sh:path rmc:seatLevelDeviationMm ;
        sh:minInclusive -3.0 ;
        sh:maxInclusive 3.0 ;
        sh:severity sh:Violation ;
        sh:message "DIM-003 FAIL: {$value} mm violates Section4.4.1" ;
    ] .

# DIM-004: Bearing pad verticality deviation
rmc:DIM-004-Shape a sh:NodeShape ;
    sh:targetClass ifc:IfcBearing ;
    sh:property [
        sh:path rmc:verticalityDeviationDeg ;
        sh:minInclusive -0.5 ;
        sh:maxInclusive 0.5 ;
        sh:severity sh:Violation ;
        sh:message "DIM-004 FAIL: {$value} deg violates Section4.4.2" ;
    ] .

